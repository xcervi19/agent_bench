# Host Caddy on VPS — public agent APIs only; RAG/DB stay on 127.0.0.1.
# Deploy: scripts/vps_deploy_caddy.sh

{
	email admin@particletico.com
}

particletico.com, www.particletico.com {
	redir https://agent.particletico.com{uri} permanent
}

# Production (~/agent_bench)
app.particletico.com {
	reverse_proxy 127.0.0.1:8000
}

agent.particletico.com {
	reverse_proxy 127.0.0.1:8002
}

# Test slots — frontend / testers hit agent only
