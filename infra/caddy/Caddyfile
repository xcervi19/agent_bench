# Host Caddy on VPS — proxies to Docker stacks on 127.0.0.1.
# Deploy: scripts/vps_deploy_caddy.sh (or copy to /etc/caddy/Caddyfile && systemctl reload caddy)

{
	email admin@particletico.com
}

# Apex → production app
particletico.com, www.particletico.com {
	redir https://app.particletico.com{uri} permanent
}

# Production (~/agent_bench, branch main)
app.particletico.com {
	reverse_proxy 127.0.0.1:8000
}

agent.particletico.com {
	reverse_proxy 127.0.0.1:8002
}

rag.particletico.com {
	reverse_proxy 127.0.0.1:8001
}

