{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-bench/claude_agent_fe/.claude/schemas/newsfind-queries.schema.json",
  "title": "newsfind-queries lightweight output (v0.2.0)",
  "description": "Compact intelligence blueprint emitted by /newsfind-queries. Stdout MUST be exactly one JSON object matching this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "schema_version",
    "topic_id",
    "topic",
    "topic_restated",
    "domain",
    "rag_context_refs",
    "web_seed_refs",
    "current_state",
    "working_thesis",
    "entities",
    "queries",
    "monitoring_plan",
    "reasoning_trace",
    "created_at"
  ],
  "properties": {
    "stage":          { "const": "queries" },
    "schema_version": { "const": "0.2.0" },
    "topic_id":       { "type": "string", "format": "uuid" },
    "topic":          { "type": "string", "minLength": 1 },
    "topic_restated": { "type": "string", "minLength": 1 },
    "domain":         { "type": "string", "minLength": 1 },

    "rag_context_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source"],
        "properties": {
          "source":   { "type": "string" },
          "used_for": { "type": "string" }
        }
      }
    },

    "web_seed_refs": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url":      { "type": "string" },
          "title":    { "type": "string" },
          "language": { "type": "string" }
        }
      }
    },

    "current_state":   { "type": "string", "minLength": 1 },
    "working_thesis":  { "type": "string", "minLength": 1 },

    "entities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actors", "regions", "primary_languages"],
      "properties": {
        "actors":            { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "regions":           { "type": "array", "items": { "type": "string" } },
        "primary_languages": { "type": "array", "items": { "type": "string" } }
      }
    },

    "queries": {
      "type": "array",
      "minItems": 10,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "q",
          "language",
          "region",
          "source_class",
          "intent",
          "freshness",
          "priority",
          "covers_entity",
          "rationale"
        ],
        "properties": {
          "id":           { "type": "string", "pattern": "^q[0-9]{2,3}$" },
          "q":            { "type": "string", "minLength": 1 },
          "language":     { "type": "string", "minLength": 2, "maxLength": 8 },
          "region":       { "type": "string" },
          "source_class": {
            "enum": [
              "primary_official",
              "specialist_outlet",
              "local_press",
              "data_feed",
              "aggregator"
            ]
          },
          "intent":         { "enum": ["context", "monitoring"] },
          "freshness":      { "enum": ["any", "24h", "7d"] },
          "priority":       { "type": "integer", "minimum": 1, "maximum": 5 },
          "covers_entity":  { "type": "array", "items": { "type": "string" } },
          "rationale":      { "type": "string", "minLength": 1 }
        }
      }
    },

    "monitoring_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_cadence", "trigger_terms"],
      "properties": {
        "default_cadence": { "type": "string" },
        "trigger_terms":   { "type": "array", "items": { "type": "string" } }
      }
    },

    "reasoning_trace": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["phase", "summary"],
        "properties": {
          "phase":   { "enum": ["P1", "P2", "P3", "P4"] },
          "summary": { "type": "string" }
        }
      }
    },

    "created_at": { "type": "string", "format": "date-time" }
  }
}
