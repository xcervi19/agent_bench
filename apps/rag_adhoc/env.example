# Same async URL as the main app (e.g. shared compose Postgres: postgresql+asyncpg://user:pass@localhost:5432/db)
RAG_ADHOC_DATABASE_URL=postgresql+asyncpg://agentic:agentic@localhost:5432/agentic

# Optional: semantic search (text-embedding-3-small); if empty, search falls back to text filters
RAG_ADHOC_OPENAI_API_KEY=

# Optional: if set, clients must send matching X-API-Key
RAG_ADHOC_API_KEY=
